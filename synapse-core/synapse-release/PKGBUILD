pkgname=synapse-release
pkgver=0.1.0
pkgrel=1
pkgdesc="Synapse OS system identity and branding files"
arch=('any')
license=('MIT')

# 1. Keep the source array flat and clean
source=('os-release'
        'issue'
        'issue.net'
	'motd'
	'lsb-release')

# Use the exact checksums you generated earlier for these 5 files
sha256sums=('d82f2c79551860425084d409322319ed53e1a1150634a7d5ef3cd37065c3921d'
            'e0db485530844f667d74919def9e74bc38567918881201468622c20e222727cc'
            'fc9e24ceffa72654a788fe484b0273b35972de2fdf85c5e27d6adde1df34daac'
            '25a247e83cca6d24f2d4ef7338413312cd6c7c55e0f24bf2da4f13670b471fc2'
            '1465df859c67e027a506bbe40339ce8944e2607cf6419887bd89a99aa2146c2f')

package() {

  # System identity
  install -Dm644 "os-release" "$pkgdir/usr/lib/os-release"
  install -Dm644 "os-release" "$pkgdir/etc/os-release"
  install -Dm644 "issue" "$pkgdir/etc/issue"
  install -Dm644 "issue.net" "$pkgdir/etc/issue.net"
  install -Dm644 "motd" "$pkgdir/etc/motd"
  install -Dm644 "motd" "$pkgdir/etc/lsb-release"

}
